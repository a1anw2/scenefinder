{
  "ai": {
    "url": "http://localhost:1234/v1/chat/completions",
    "model": "google/gemma-4-12b-qat"
  },
  "embedding": {
    "model": "Xenova/all-MiniLM-L6-v2",
    "dimensions": 384,
    "cacheDir": "./cache/hf"
  },
  "lancedb": {
    "path": "./lancedb.db",
    "tableName": "scenes"
  },
  "media": {
    "root": "/path/to/movies/mount"
  },
  "image": {
    "width": 512,
    "height": 512,
    "quality": 85,
    "thumbnailWidth": 100,
    "thumbnailHeight": 100
  },
  "ffmpeg": {
    "path": "/usr/bin/ffmpeg",
    "inputPath": "input.mp4",
    "outputDir": "./output",
    "captureInterval": 10
  },
  "server": {
    "host": "0.0.0.0",
    "port": 19720,
    "publicUrl": "http://localhost:19720",
    "authToken": ""
  },
  "cache": {
    "dir": "./cache/frames",
    "maxAgeHours": 24
  }
}
