{
  "name": "scenefinder",
  "version": "1.0.0",
  "description": "Movie scene capture and vectorization pipeline",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node --esm src/index.ts",
    "lint": "prettier --check \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "search": "tsx src/search.ts",
    "inspect": "tsx src/inspect.js",
    "compact": "tsx src/compact.ts",
    "server": "tsx src/server.ts"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@lancedb/lancedb": "^0.31.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.18.1",
    "fluent-ffmpeg": "^2.1.3",
    "sharp": "^0.35.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^26.1.0",
    "prettier": "^3.9.4",
    "ts-node": "^10.9.2",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
}
